generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Category {
  WORK
  STUDY
  PERSONAL
  OTHER
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}
enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id Int @id @default(autoincrement())
  title String
  category Category
  status Status
  priority Priority
  created_at DateTime @default(now())
  update_at DateTime @updatedAt
  notes Note[]
}

model Note{
  id Int @id @default(autoincrement())
  note String
  task_id Int
  task Task @relation(fields: [task_id], references: [id])
  created_at DateTime @default(now())
  update_at DateTime @updatedAt
}

